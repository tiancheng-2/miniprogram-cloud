/* app.wxss - 精致优雅全局样式 */

/* 页面基础背景 - 统一渐变（首页风格）*/
page {
  background: #F8FAFC;  /* 改为统一纯色 */
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "STHeiti", "Microsoft Yahei", Tahoma, Simsun, sans-serif;
}

/* 精致卡片基础类 */
.glass-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(150%);
  -webkit-backdrop-filter: blur(20rpx) saturate(150%);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border-radius: 20rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-card:active {
  transform: translateY(-4rpx) scale(1.01);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

/* 主要按钮 - 黑色渐变 */
.glass-btn-dark {
  background: linear-gradient(135deg, #1a1a1a 0%, #333 100%);
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  border-radius: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  color: #FFFFFF;
}

.glass-btn-dark:active {
  transform: translateY(-2rpx) scale(1.02);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

/* 次要按钮 - 白色卡片风格 */
.glass-btn-light {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(150%);
  -webkit-backdrop-filter: blur(20rpx) saturate(150%);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border-radius: 14rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-btn-light:active {
  background: rgba(255, 255, 255, 0.98);
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* 输入框 */
.glass-input {
  background: rgba(0, 0, 0, 0.02);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.02);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.glass-input:focus {
  background: rgba(255, 255, 255, 0.5);
  border-color: #666;
  box-shadow: 0 0 0 3rpx rgba(0, 0, 0, 0.02);
}

/* 渐变文字（用于标题）*/
.gradient-text {
  background: linear-gradient(135deg, #1a1a1a 0%, #666 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 衬线字体类（用于重要标题）*/
.serif-text {
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 动画 */
@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
