/* ===== 味觉空间 · 全局样式规范 ===== */
/* 关键词：干净 / 温暖 / 记录感 / 不像系统表单 */

/* ===== 1. CSS 变量定义 ===== */
page {
  /* 品牌主色 */
  --color-primary: #FF8A3D;
  --color-primary-soft: #FFE4D2;
  
  /* 状态色 */
  --color-danger: #FF5A5A;
  
  /* 背景色 */
  --color-bg-page: #F6F7F8;
  --color-bg-card: #FFFFFF;
  
  /* 文字颜色 */
  --color-text-main: #222222;
  --color-text-normal: #555555;
  --color-text-sub: #999999;
  
  /* 圆角 */
  --radius-card: 20rpx;
  --radius-button: 999rpx;
  --radius-tag: 12rpx;
  --radius-input: 16rpx;
  
  /* 阴影 */
  --shadow-card: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  --shadow-popup: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
  
  /* 字号 */
  --font-title: 40rpx;
  --font-subtitle: 32rpx;
  --font-body: 28rpx;
  --font-caption: 24rpx;
  --font-tag: 22rpx;
  
  /* 页面背景 */
  background: var(--color-bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

/* ===== 2. 基础通用组件 ===== */

/* 卡片 */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

/* 标签组 */
.tag {
  display: inline-block;
  font-size: var(--font-tag);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-tag);
  font-weight: 400;
}

.tag-primary {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.tag-danger {
  background: #F2F2F2;
  color: var(--color-text-sub);
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  font-size: var(--font-body);
  font-weight: 500;
  border-radius: var(--radius-button);
  transition: opacity 0.3s ease;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
}

.btn-secondary {
  background: #EFEFEF;
  color: var(--color-text-normal);
}

.btn-danger {
  background: var(--color-danger);
  color: #FFFFFF;
}

/* 输入框 */
.input {
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 20rpx;
  font-size: var(--font-body);
  color: var(--color-text-main);
  border: none;
}

.input::placeholder {
  color: var(--color-text-sub);
}

.textarea {
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 20rpx;
  font-size: var(--font-body);
  color: var(--color-text-main);
  border: none;
  min-height: 160rpx;
  line-height: 1.6;
}

.textarea::placeholder {
  color: var(--color-text-sub);
}

/* ===== 3. 文字规范 ===== */
.text-title {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-main);
  line-height: 1.4;
}

.text-subtitle {
  font-size: var(--font-subtitle);
  font-weight: 500;
  color: var(--color-text-main);
  line-height: 1.4;
}

.text-body {
  font-size: var(--font-body);
  font-weight: 400;
  color: var(--color-text-normal);
  line-height: 1.6;
}

.text-caption {
  font-size: var(--font-caption);
  font-weight: 400;
  color: var(--color-text-sub);
  line-height: 1.5;
}

/* ===== 4. 布局辅助类 ===== */
.container {
  padding: 32rpx;
  min-height: 100vh;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 20rpx;
}

/* ===== 5. 固定底部按钮区域 ===== */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.fixed-bottom .action-buttons {
  display: flex;
  gap: 16rpx;
}

.fixed-bottom .action-buttons .btn {
  flex: 1;
}

/* ===== 6. 特定组件样式 ===== */

/* 搜索框 */
.search-box {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.search-input {
  font-size: var(--font-body);
  color: var(--color-text-sub);
}

/* 统计卡片 */
.stat-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-number {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
}

/* 餐厅卡片 */
.restaurant-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.restaurant-card:active {
  transform: scale(0.98);
}

.restaurant-name {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.restaurant-address {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

/* 菜品卡片 */
.dish-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  display: flex;
  transition: transform 0.3s ease;
}

.dish-card:active {
  transform: scale(0.98);
}

.dish-name {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
}

.dish-note {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

/* 评分标签 */
.rating-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  font-weight: 500;
}

.rating-badge.must {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.rating-badge.avoid {
  background: #F2F2F2;
  color: var(--color-text-sub);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow-popup);
}

.modal-title {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-desc {
  font-size: var(--font-body);
  color: var(--color-text-normal);
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-actions .btn {
  flex: 1;
}

/* ===== 7. 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.8;
}

/* ===== 8. 动画 ===== */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

.fade-in-up {
  animation: fadeInUp 0.4s ease;
}
