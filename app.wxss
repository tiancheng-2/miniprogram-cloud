/* app.wxss - 新视觉规范全局样式（已修复输入框高度问题）*/

/* ==================== CSS 变量定义 ==================== */
page {
  /* 背景色 */
  --color-bg-page: #F9F9F9;          /* 奶油白 */
  --color-bg-card: #FFFFFF;           /* 纯白卡片 */
  
  /* 文字颜色 */
  --color-text-main: #2D2D2D;        /* 深炭灰（主要文字）*/
  --color-text-normal: #5A5A5A;      /* 灰色（正文）*/
  --color-text-sub: #A0A0A0;         /* 浅灰（次要说明）*/
  
  /* 品牌色 */
  --color-must-try: #66BB6A;         /* 森林绿（必点）*/
  --color-avoid: #EF5350;            /* 珊瑚粉红（避坑）*/
  --color-must-try-soft: #E8F5E9;    /* 必点浅色背景 */
  --color-avoid-soft: #FFEBEE;       /* 避坑浅色背景 */
  
  /* 圆角 */
  --radius-card: 12px;
  --radius-button: 12px;
  --radius-tag: 8px;
  --radius-input: 12px;
  
  /* 阴影 */
  --shadow-card: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-popup: 0 8px 24px rgba(0, 0, 0, 0.12);
  
  /* 字号 */
  --font-title: 36rpx;
  --font-subtitle: 30rpx;
  --font-body: 28rpx;
  --font-caption: 24rpx;
  --font-tag: 22rpx;
  
  /* 字体家族 */
  --font-serif: 'Source Serif Pro', 'Noto Serif SC', Georgia, serif;
  --font-sans: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Inter', sans-serif;
  
  /* 页面背景 */
  background: var(--color-bg-page);
  min-height: 100vh;
  font-family: var(--font-sans);
  color: var(--color-text-main);
}

/* ==================== 通用组件样式 ==================== */

/* 卡片 */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

/* 标题（使用衬线体）*/
.title {
  font-family: var(--font-serif);
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-main);
  line-height: 1.4;
}

.subtitle {
  font-family: var(--font-serif);
  font-size: var(--font-subtitle);
  font-weight: 500;
  color: var(--color-text-main);
  line-height: 1.4;
}

/* 正文 */
.body-text {
  font-family: var(--font-sans);
  font-size: var(--font-body);
  color: var(--color-text-normal);
  line-height: 1.6;
}

.caption-text {
  font-family: var(--font-sans);
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  line-height: 1.5;
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: var(--font-tag);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-tag);
  font-weight: 400;
  background: #F2F2F2;
  color: var(--color-text-sub);
}

.tag-must {
  background: var(--color-must-try-soft);
  color: var(--color-must-try);
  font-weight: 500;
}

.tag-avoid {
  background: var(--color-avoid-soft);
  color: var(--color-avoid);
  font-weight: 500;
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  font-size: var(--font-body);
  font-weight: 500;
  border-radius: var(--radius-button);
  transition: opacity 0.3s ease;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: var(--color-must-try);
  color: #FFFFFF;
}

.btn-secondary {
  background: #EFEFEF;
  color: var(--color-text-normal);
}

.btn-danger {
  background: var(--color-avoid);
  color: #FFFFFF;
}

/* ==================== 输入框（已修复）==================== */

.input {
  width: 100%;
  box-sizing: border-box;
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 24rpx 20rpx;              /* ✅ 修复：增加垂直内边距 */
  font-size: var(--font-body);
  color: var(--color-text-main);
  border: none;
  min-height: 88rpx;                 /* ✅ 修复：添加最小高度 */
  line-height: 1.5;                  /* ✅ 修复：添加行高 */
  display: flex;                     /* ✅ 修复：flex布局让文字垂直居中 */
  align-items: center;               /* ✅ 修复：垂直居中 */
}

.input::placeholder {
  color: var(--color-text-sub);
}

.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 20rpx;
  font-size: var(--font-body);
  color: var(--color-text-main);
  border: none;
  min-height: 120rpx;                /* ✅ 修复：增加最小高度 */
  line-height: 1.6;
}

.textarea::placeholder {
  color: var(--color-text-sub);
}

/* ==================== 布局辅助类 ==================== */

.container {
  padding: 32rpx;
  min-height: 100vh;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-family: var(--font-serif);
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 20rpx;
}

/* ==================== 评分徽章 ==================== */

.rating-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  font-weight: 500;
}

.rating-badge-must {
  background: var(--color-must-try-soft);
  color: var(--color-must-try);
}

.rating-badge-avoid {
  background: var(--color-avoid-soft);
  color: var(--color-avoid);
}

/* ==================== 空状态 ==================== */

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.8;
}

/* ==================== 弹窗 ==================== */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow-popup);
}

.modal-title {
  font-family: var(--font-serif);
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-desc {
  font-size: var(--font-body);
  color: var(--color-text-normal);
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-actions .btn {
  flex: 1;
}

/* ==================== 固定底部 ==================== */

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

/* ==================== 动画 ==================== */

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

.fade-in-up {
  animation: fadeInUp 0.4s ease;
}
