<!--pages/dish/dish.wxml-->
<view class="container {{isEditing ? 'editing' : ''}}">
  <!-- 非编辑模式 -->
  <view wx:if="{{!isEditing}}" class="view-mode">
    <!-- 菜品照片 -->
    <view wx:if="{{photoUrl}}" class="dish-photo-section">
      <image class="dish-main-photo" src="{{photoUrl}}" mode="aspectFill" bindtap="onPreviewPhoto"></image>
    </view>

    <!-- 菜品头部 -->
    <view class="dish-header">
      <view class="name-row">
        <view class="dish-name">{{dishName}}</view>
        <view class="edit-icon" bindtap="onEdit">✏︎</view>
      </view>
      
      <view class="dish-rating {{rating === 'must-try' ? 'must' : 'avoid'}}">
        {{rating === 'must-try' ? '👍 必点' : '⚠️ 避坑'}}
      </view>
      
      <view wx:if="{{restaurantName}}" class="dish-restaurant" bindtap="goToRestaurant">
        📍 {{restaurantName}}
      </view>
    </view>

    <!-- 菜品笔记 -->
    <view wx:if="{{note}}" class="section">
      <view class="section-title">菜品笔记</view>
      <view class="note-text">{{note}}</view>
    </view>

    <!-- 标签 -->
    <view wx:if="{{tags && tags.length > 0}}" class="section">
      <view class="section-title">标签</view>
      <view class="tags-list">
        <view class="tag" wx:for="{{tags}}" wx:key="index">{{item}}</view>
      </view>
    </view>

    <!-- 删除按钮 -->
    <view class="delete-section">
      <view class="btn btn-danger" bindtap="onDelete">删除这道菜</view>
    </view>
  </view>

  <!-- 编辑模式 -->
  <view wx:else class="edit-mode">
    <view class="edit-title">编辑菜品</view>

    <!-- 编辑表单 -->
    <view class="edit-form">
      <!-- 菜品名称 -->
      <view class="form-item">
        <view class="form-label">
          <text>菜品名称</text>
          <text class="char-count">{{editingName.length}}/20</text>
        </view>
        <input 
          class="input" 
          placeholder="菜品名称" 
          value="{{editingName}}" 
          bindinput="onEditNameInput"
          maxlength="20"
        />
      </view>

      <!-- 评分 -->
      <view class="form-item">
        <view class="form-label">评分</view>
        <view class="rating-buttons">
          <view 
            class="rating-btn {{editingRating === 'must-try' ? 'active must' : ''}}" 
            bindtap="onSelectEditRating" 
            data-rating="must-try"
          >
            <text class="rating-text">👍 必点</text>
          </view>
          <view 
            class="rating-btn {{editingRating === 'avoid' ? 'active avoid' : ''}}" 
            bindtap="onSelectEditRating" 
            data-rating="avoid"
          >
            <text class="rating-text">⚠️ 避坑</text>
          </view>
        </view>
      </view>

      <!-- 菜品笔记 -->
      <view class="form-item">
        <view class="form-label">
          <text>菜品笔记</text>
          <text class="char-count">{{editingNote.length}}/25</text>
        </view>
        <textarea 
          class="textarea" 
          placeholder="记录一下这道菜..." 
          value="{{editingNote}}" 
          bindinput="onEditNoteInput"
          maxlength="25"
          auto-height
        />
      </view>

      <!-- 标签 -->
      <view class="form-item">
        <view class="form-label">
          <text>标签</text>
          <text class="char-count">{{editingTags.length}}/30</text>
        </view>
        <input 
          class="input" 
          placeholder="例如: 辣 川菜 招牌" 
          value="{{editingTags}}" 
          bindinput="onEditTagsInput"
          maxlength="30"
        />
      </view>

      <!-- 菜品照片 -->
      <view class="form-item">
        <view class="form-label">菜品照片（可选）</view>
        
        <view wx:if="{{editingPhotoUrl}}" class="photo-preview">
          <image class="photo-image" src="{{editingPhotoUrl}}" mode="aspectFill"></image>
          <view class="photo-delete" bindtap="onDeleteEditPhoto" catchtap>
            <text class="delete-icon">✕</text>
          </view>
        </view>
        
        <view wx:else class="photo-upload" bindtap="onChooseEditImage">
          <text class="upload-icon">📷</text>
          <text class="upload-text">添加照片</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>

    <!-- 操作按钮 -->
    <view class="fixed-bottom">
      <view class="action-buttons">
        <view class="btn btn-secondary" bindtap="onCancelEdit">取消</view>
        <view class="btn btn-primary" bindtap="onSaveEdit">保存</view>
      </view>
    </view>
  </view>
</view>
