/* pages/dish/dish.wxss */

.container {
  padding: 32rpx;
  min-height: 100vh;
}

.container.editing {
  padding-bottom: 180rpx;
}

/* ===== 查看模式 ===== */

/* 菜品照片 */
.dish-photo-section {
  width: calc(100% + 64rpx);
  margin: -32rpx -32rpx 24rpx -32rpx;
  height: 0;
  padding-bottom: 56.25%; /* 16:9 */
  position: relative;
  overflow: hidden;
  background: #FAFAFA;
}

.dish-main-photo {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

/* 菜品头部 */
.dish-header {
  margin-bottom: 32rpx;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.dish-name {
  font-family: var(--font-serif);
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-main);
  flex: 1;
  padding-right: 16rpx;
  line-height: 1.3;
}

.edit-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  color: var(--color-text-sub);
  background: #FAFAFA;
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.edit-icon:active {
  background: #F0F0F0;
  transform: scale(0.92);
}

.dish-rating {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-body);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.dish-rating.must {
  background: var(--color-must-try-soft);
  color: var(--color-must-try);
}

.dish-rating.avoid {
  background: var(--color-avoid-soft);
  color: var(--color-avoid);
}

.dish-restaurant {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  padding: 12rpx 0;
}

/* 章节 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-family: var(--font-serif);
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 16rpx;
}

.note-text {
  background: #FAFAFA;
  padding: 20rpx;
  border-radius: var(--radius-input);
  font-size: var(--font-body);
  color: var(--color-text-main);
  line-height: 1.8;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 删除区域 */
.delete-section {
  margin-top: 80rpx;
}

/* ===== 编辑模式 ===== */

.edit-title {
  font-family: var(--font-serif);
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 24rpx;
}

.edit-form {
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: var(--font-body);
  font-weight: 500;
  color: var(--color-text-main);
}

.char-count {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* 评分按钮 */
.rating-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.rating-btn {
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 24rpx 0;
  text-align: center;
  transition: all 0.2s ease;
}

.rating-btn:active {
  transform: scale(0.98);
}

.rating-btn.active.must {
  background: var(--color-must-try-soft);
}

.rating-btn.active.avoid {
  background: var(--color-avoid-soft);
}

.rating-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 500;
}

.rating-btn.active.must .rating-text {
  color: var(--color-must-try);
}

.rating-btn.active.avoid .rating-text {
  color: var(--color-avoid);
}

/* 照片上传 */
.photo-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-input);
  overflow: hidden;
  background: #FAFAFA;
}

.photo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.photo-delete:active {
  transform: scale(0.9);
}

.delete-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 300;
}

.photo-upload {
  width: 100%;
  height: 300rpx;
  background: #FAFAFA;
  border: 2rpx dashed #E0E0E0;
  border-radius: var(--radius-input);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.photo-upload:active {
  background: #F0F0F0;
  border-color: #D0D0D0;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* 底部占位 */
.bottom-placeholder {
  height: 160rpx;
}

/* 底部按钮 */
.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
