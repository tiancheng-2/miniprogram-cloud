/* pages/dish/dish.wxss - 菜品详情（遵循视觉规范）*/

.container {
  padding: 32rpx;
  min-height: 100vh;
}

/* ===== 非编辑模式 ===== */

/* 菜品顶部信息 */
.dish-header {
  margin-bottom: 24rpx;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.dish-name {
  flex: 1;
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-main);
  letter-spacing: 0.5rpx;
  line-height: 1.3;
  padding-right: 16rpx;
}

.edit-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  color: var(--color-text-sub);
  background: #FAFAFA;
  border-radius: 50%;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.edit-icon:active {
  background: #F0F0F0;
  transform: scale(0.92);
}

.dish-tag {
  display: inline-block;
  font-size: var(--font-tag);
  font-weight: 500;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-tag);
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.dish-tag.must-try {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.dish-tag.avoid {
  background: #F2F2F2;
  color: var(--color-text-sub);
}

.dish-restaurant {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  letter-spacing: 0.5rpx;
}

/* 菜品照片 */
.photo-section {
  margin-bottom: 24rpx;
}

.photo-swiper {
  width: 100%;
  height: 480rpx;
  border-radius: var(--radius-card);
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
}

/* 菜品笔记 */
.note-section {
  margin-bottom: 32rpx;
}

.note-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.note-text {
  background: #FAFAFA;
  padding: 20rpx;
  border-radius: var(--radius-input);
  font-size: var(--font-body);
  color: var(--color-text-main);
  line-height: 1.8;
  letter-spacing: 0.5rpx;
}

.note-empty {
  background: #FAFAFA;
  padding: 20rpx;
  border-radius: var(--radius-input);
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* 标签区域 */
.tags-section {
  margin-bottom: 32rpx;
}

.tags-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 6rpx 16rpx;
  background: #F2F2F2;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  color: var(--color-text-sub);
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

/* 删除按钮 */
.delete-section {
  margin-top: 48rpx;
}

.delete-btn {
  background: var(--color-bg-card);
  border-radius: var(--radius-button);
  padding: 24rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  transition: opacity 0.2s ease;
}

.delete-btn:active {
  opacity: 0.8;
}

.delete-btn-text {
  font-size: var(--font-body);
  color: var(--color-danger);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* ===== 编辑模式 ===== */
.edit-mode {
  padding-bottom: 0;
}

.edit-title {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 24rpx;
  letter-spacing: 0.5rpx;
}

.edit-form {
  margin-bottom: 32rpx;
}

.edit-item {
  margin-bottom: 24rpx;
}

.edit-label {
  font-size: var(--font-body);
  color: var(--color-text-main);
  margin-bottom: 12rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.char-count {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* 编辑输入框 */
.edit-input, .edit-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 20rpx;
  font-size: var(--font-body);
  color: var(--color-text-main);
  letter-spacing: 0.5rpx;
}

.edit-input {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  line-height: 1.5;
}

.edit-textarea {
  min-height: 160rpx;
  line-height: 1.6;
}

.edit-input::placeholder, .edit-textarea::placeholder {
  color: var(--color-text-sub);
  font-weight: 400;
}

/* 评分按钮 */
.rating-buttons {
  display: flex;
  gap: 12rpx;
}

.rating-btn {
  flex: 1;
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 24rpx 0;
  text-align: center;
  transition: all 0.2s ease;
}

.rating-btn:active {
  transform: scale(0.98);
}

.rating-btn.active {
  background: var(--color-primary-soft);
}

.rating-btn.must.active {
  background: var(--color-primary-soft);
}

.rating-btn.avoid.active {
  background: #F2F2F2;
}

.rating-btn-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.rating-btn.active .rating-btn-text {
  color: var(--color-text-main);
}

.rating-btn.must.active .rating-btn-text {
  color: var(--color-primary);
}

/* 照片上传 */
.photo-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-input);
  overflow: hidden;
  background: #FAFAFA;
}

.photo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.photo-delete:active {
  transform: scale(0.9);
}

.delete-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 300;
}

.photo-upload {
  width: 100%;
  height: 300rpx;
  background: #FAFAFA;
  border: 2rpx dashed #E0E0E0;
  border-radius: var(--radius-input);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.photo-upload:active {
  background: #F0F0F0;
  border-color: #D0D0D0;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

/* 编辑按钮区域 */
.action-buttons {
  position: fixed;
  bottom: 32rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 330rpx;
  background: #EFEFEF;
  border-radius: var(--radius-button);
  padding: 24rpx 0;
  text-align: center;
  font-size: var(--font-body);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  color: var(--color-text-normal);
  transition: opacity 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.save {
  background: var(--color-primary);
}

.action-btn-text {
  font-size: var(--font-body);
  color: var(--color-text-normal);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.action-btn.save .action-btn-text {
  color: #FFFFFF;
}
