/* pages/index/index.wxss - 完全自适应版本 */

/* 页面容器 */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ===== 固定顶部区域 ===== */
.fixed-header {
  flex-shrink: 0;
  padding: 16rpx 32rpx 0;
  background: #F8FAFC;
  z-index: 10;
}

/* ===== 搜索框 ===== */
.search-box {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(150%);
  -webkit-backdrop-filter: blur(20rpx) saturate(150%);
  border-radius: 16rpx;
  padding: 32rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.search-box:active {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.search-placeholder {
  font-size: 32rpx;
  font-weight: 400;
  color: #999;
  letter-spacing: 1rpx;
}

/* ===== 统计卡片 ===== */
.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(150%);
  -webkit-backdrop-filter: blur(20rpx) saturate(150%);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.stat-card:active {
  transform: translateY(-4rpx) scale(1.02);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.stat-number {
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #666 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 24rpx;
  font-weight: 300;
  color: #666;
  letter-spacing: 1rpx;
}

/* ===== 可滚动内容区域（关键：自适应） ===== */
.scroll-content {
  flex: 1;  /* 自动填充剩余空间 */
  padding: 16rpx 32rpx;  /* 左右和顶部内边距 */
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));  /* 底部留出按钮空间 */
  box-sizing: border-box;
  overflow-y: auto;  /* 允许垂直滚动 */
}

/* ===== 餐厅列表 ===== */
.restaurant-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

/* 餐厅卡片 */
.restaurant-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(150%);
  -webkit-backdrop-filter: blur(20rpx) saturate(150%);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
}

.restaurant-card:active {
  transform: translateY(-8rpx) scale(1.01);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

/* 餐厅信息 */
.restaurant-info {
  padding: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.restaurant-header {
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.restaurant-name {
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  margin-bottom: 8rpx;
  line-height: 1.4;
  word-break: break-all;
}

.restaurant-address {
  font-size: 24rpx;
  color: #737373;
  font-weight: 300;
  letter-spacing: 0.5rpx;
  line-height: 1.5;
  margin-bottom: 12rpx;
  word-break: break-all;
}

/* 标签 */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.tag {
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #666;
  font-weight: 400;
  letter-spacing: 0.5rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* 菜品统计 */
.dish-stats {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: auto;
  flex-shrink: 0;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.dish-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.stat-badge {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  font-size: 22rpx;
}

.stat-badge.must {
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  color: white;
}

.stat-badge.avoid {
  background: linear-gradient(135deg, #e5e5e5 0%, #d4d4d4 100%);
  color: #525252;
  font-weight: 500;
}

.stat-count {
  font-weight: 400;
  color: #666;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 240rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.8;
}

/* 删除 .bottom-placeholder（不再需要） */

/* ===== 固定底栏 ===== */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* 新增按钮 */
.add-button {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(150%);
  -webkit-backdrop-filter: blur(20rpx) saturate(150%);
  color: #1a1a1a;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 12rpx;
  padding: 28rpx 96rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.add-button:active {
  transform: translateY(-4rpx) scale(1.02);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
}