/* pages/index/index.wxss - 新视觉规范 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--color-bg-page);
}

/* ===== 搜索框 ===== */
.search-bar {
  margin: 20rpx 32rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}

.search-bar:active {
  transform: scale(0.98);
}

.search-icon {
  font-size: 28rpx;
  opacity: 0.5;
}

.search-placeholder {
  flex: 1;
  font-size: var(--font-body);
  color: var(--color-text-sub);
}

/* ===== 统计卡片 ===== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}

.stat-item:active {
  transform: translateY(-4rpx);
}

.stat-number {
  font-family: var(--font-serif);
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-label {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* 必点和避坑的特殊样式 */
.stat-must .stat-number {
  color: var(--color-must-try);
}

.stat-avoid .stat-number {
  color: var(--color-avoid);
}

/* ===== 滚动内容区 ===== */
.scroll-content {
  flex: 1;
  height: 0;
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* ===== 餐厅Masonry网格（2列）===== */
.restaurant-masonry {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding-bottom: 120rpx;
}

.restaurant-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
  break-inside: avoid;
}

.restaurant-card:active {
  transform: scale(0.98);
}

/* 封面区域 */
.card-cover {
  width: 100%;
  height: 160rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-char {
  font-family: var(--font-serif);
  font-size: 72rpx;
  font-weight: 600;
  color: var(--color-must-try);
  opacity: 0.8;
}

/* 卡片主体 */
.card-body {
  padding: 20rpx;
}

.restaurant-name {
  font-family: var(--font-serif);
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 12rpx;
  line-height: 1.4;
  /* 最多显示2行 */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}

.restaurant-address {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  margin-bottom: 12rpx;
  line-height: 1.5;
  /* 最多显示1行 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background: #F2F2F2;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* 菜品统计徽章 */
.dish-stats {
  display: flex;
  gap: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F2F2F2;
}

.stat-badge {
  flex: 1;
  padding: 8rpx 0;
  border-radius: var(--radius-tag);
  text-align: center;
  font-size: var(--font-tag);
  font-weight: 500;
}

.stat-badge-must {
  background: var(--color-must-try-soft);
  color: var(--color-must-try);
}

.stat-badge-avoid {
  background: var(--color-avoid-soft);
  color: var(--color-avoid);
}

.badge-text {
  font-size: var(--font-tag);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.8;
  white-space: pre-line;
}

/* ===== 底部占位 ===== */
.bottom-placeholder {
  height: 120rpx;
}

/* ===== 固定底部按钮 ===== */
.fixed-add-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, var(--color-bg-page) 20%);
  pointer-events: none;
  z-index: 100;
}

.add-btn {
  background: var(--color-must-try);
  color: #FFFFFF;
  border-radius: var(--radius-button);
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 187, 106, 0.3);
  pointer-events: auto;
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.add-icon {
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

.add-text {
  font-size: var(--font-body);
  font-weight: 500;
  letter-spacing: 1rpx;
}
