/* pages/index/index.wxss - 首页样式（遵循视觉规范）*/

/* ===== 容器 ===== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ===== 固定顶部区域 ===== */
.fixed-header {
  flex-shrink: 0;
  padding: 16rpx 32rpx 0;
  background: var(--color-bg-page);
  z-index: 10;
}

/* ===== 搜索框 ===== */
.search-box {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}

.search-box:active {
  transform: scale(0.98);
}

.search-placeholder {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  letter-spacing: 0.5rpx;
}

/* ===== 统计卡片 ===== */
.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.stat-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}

.stat-card:active {
  transform: translateY(-4rpx);
}

.stat-number {
  font-size: var(--font-stat);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  letter-spacing: 0.5rpx;
}

/* ===== 可滚动内容区域 ===== */
.scroll-content {
  flex: 1;
  padding: 16rpx 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
}

/* ===== 餐厅列表 ===== */
.restaurant-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

/* 餐厅卡片 */
.restaurant-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
}

.restaurant-card:active {
  transform: scale(0.98);
}

/* 餐厅信息 */
.restaurant-info {
  padding: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.restaurant-header {
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.restaurant-name {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
  line-height: 1.4;
  word-break: break-all;
}

.restaurant-address {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  font-weight: 400;
  letter-spacing: 0.5rpx;
  line-height: 1.5;
  margin-bottom: 12rpx;
  word-break: break-all;
}

/* 标签 */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.tag {
  padding: 6rpx 16rpx;
  background: #F2F2F2;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  color: var(--color-text-sub);
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

/* 菜品统计 */
.dish-stats {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: auto;
  flex-shrink: 0;
  padding-top: 8rpx;
  border-top: 1rpx solid #F2F2F2;
}

.dish-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-caption);
}

.stat-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-tag);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  font-size: var(--font-tag);
}

.stat-badge.must {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.stat-badge.avoid {
  background: #F2F2F2;
  color: var(--color-text-sub);
}

.stat-count {
  font-weight: 400;
  color: var(--color-text-sub);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 240rpx 0;
}

.empty-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.8;
}

/* ===== 固定底栏 ===== */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  flex-shrink: 0;
  background: var(--color-bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

/* 新增按钮 */
.add-button {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-button);
  padding: 24rpx 96rpx;
  font-size: var(--font-body);
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: opacity 0.2s ease;
}

.add-button:active {
  opacity: 0.8;
}
