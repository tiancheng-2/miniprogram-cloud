/* pages/search/search.wxss */

.container {
  padding: 32rpx;
  min-height: 100vh;
}

/* ===== 搜索框 ===== */
.search-bar {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-icon {
  font-size: 28rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: var(--font-body);
  color: var(--color-text-main);
  line-height: 1.5;
}

.search-input::placeholder {
  color: var(--color-text-sub);
}

/* ===== 搜索中状态 ===== */
.searching-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 240rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: spin 1.5s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.searching-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
}

/* ===== 搜索结果 ===== */
.results-section {
  margin-top: 24rpx;
}

.result-group {
  margin-bottom: 32rpx;
}

.result-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  letter-spacing: 0.5rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}

.result-item:active {
  transform: scale(0.98);
}

.result-name {
  font-size: var(--font-body);
  font-weight: 500;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.result-info {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  letter-spacing: 0.5rpx;
}

/* ===== 空状态 ===== */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 240rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
}
