/* pages/add-dishes/add-dishes.wxss - 精致优雅新增菜品样式 */
.container {
  padding: 32rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
}

/* ===== 表单项 ===== */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #525252;
  margin-bottom: 16rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.char-count {
  font-size: 24rpx;
  color: #A3A3A3;
  font-weight: 400;
}

/* 输入框 */
.form-input, .form-textarea {
  background: rgba(0, 0, 0, 0.02);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 12rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  transition: all 0.2s ease;
  letter-spacing: 0.5rpx;
}

.form-input {
  display: flex;
  align-items: center;
  height: 88rpx;
  line-height: 40rpx;
}

.form-textarea {
  min-height: 160rpx;
  line-height: 1.6;
}

.form-input:focus, .form-textarea:focus {
  background: rgba(255, 255, 255, 0.5);
  border-color: #666;
  box-shadow: 0 0 0 3rpx rgba(0, 0, 0, 0.02);
}

.form-input::placeholder, .form-textarea::placeholder {
  color: #A3A3A3;
}

/* ===== 菜品表单 ===== */
.dish-form {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.dish-number {
  font-size: 26rpx;
  font-weight: 600;
  color: #737373;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
  z-index: 1;
  position: relative;
}

/* 评分按钮 */
.rating-buttons {
  display: flex;
  gap: 16rpx;
}

.rating-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx) saturate(150%);
  -webkit-backdrop-filter: blur(20rpx) saturate(150%);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  transition: all 0.3s ease;
}

.rating-btn:active {
  transform: scale(0.97);
}

.rating-btn.must.active {
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(253, 160, 133, 0.3);
}

.rating-btn.avoid.active {
  background: linear-gradient(135deg, #e5e5e5 0%, #d4d4d4 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.rating-btn-text {
  font-size: 28rpx;
  color: #525252;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.rating-btn.active .rating-btn-text {
  color: #FFFFFF;
}

.rating-btn.avoid.active .rating-btn-text {
  color: #1a1a1a;
}

/* ===== 底部固定区域 ===== */
.bottom-placeholder {
  height: 160rpx;
}

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, 
    rgba(248, 249, 250, 0) 0%, 
    rgba(248, 249, 250, 0.95) 20%,
    rgba(248, 249, 250, 0.98) 100%
  );
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  border-radius: 12rpx;
  padding: 28rpx 0;
  text-align: center;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.btn-cancel:active {
  background: rgba(255, 255, 255, 0.98);
  transform: scale(0.98);
}

.btn-save {
  background: linear-gradient(135deg, #1a1a1a 0%, #333 100%);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.btn-save:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.action-btn-text {
  font-size: 28rpx;
  color: #525252;
  font-weight: 500;
  letter-spacing: 1rpx;
  z-index: 1;
  position: relative;
}

.btn-save .action-btn-text {
  color: #FFFFFF;
}

/* ===== 图片上传 ===== */

/* 照片预览 */
.photo-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.02);
}

.photo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.photo-delete:active {
  background: rgba(0, 0, 0, 0.8);
  transform: scale(0.9);
}

.delete-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 300;
}

/* 上传按钮 */
.photo-upload {
  width: 100%;
  height: 300rpx;
  background: rgba(0, 0, 0, 0.02);
  border: 2rpx dashed rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: all 0.3s ease;
}

.photo-upload:active {
  background: rgba(0, 0, 0, 0.04);
  border-color: rgba(0, 0, 0, 0.2);
  transform: scale(0.98);
}

.upload-icon {
  font-size: 80rpx;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: #999;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}