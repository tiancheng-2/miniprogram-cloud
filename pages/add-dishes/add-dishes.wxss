/* pages/add-dishes/add-dishes.wxss */

.container {
  padding: 32rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
}

/* ===== 菜品表单卡片 ===== */
.dish-form {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.dish-number {
  font-size: var(--font-caption);
  font-weight: 600;
  color: var(--color-text-sub);
  margin-bottom: 20rpx;
  letter-spacing: 0.5rpx;
}

/* ===== 表单项 ===== */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: var(--font-body);
  font-weight: 500;
  color: var(--color-text-main);
}

.char-count {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* ===== 评分按钮 ===== */
.rating-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.rating-btn {
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 24rpx 0;
  text-align: center;
  transition: all 0.2s ease;
}

.rating-btn:active {
  transform: scale(0.98);
}

.rating-btn.active.must {
  background: var(--color-must-try-soft);
}

.rating-btn.active.avoid {
  background: var(--color-avoid-soft);
}

.rating-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 500;
}

.rating-btn.active.must .rating-text {
  color: var(--color-must-try);
}

.rating-btn.active.avoid .rating-text {
  color: var(--color-avoid);
}

/* ===== 照片上传 ===== */
.photo-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-input);
  overflow: hidden;
  background: #FAFAFA;
}

.photo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.photo-delete:active {
  transform: scale(0.9);
}

.delete-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 300;
}

.photo-upload {
  width: 100%;
  height: 300rpx;
  background: #FAFAFA;
  border: 2rpx dashed #E0E0E0;
  border-radius: var(--radius-input);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.photo-upload:active {
  background: #F0F0F0;
  border-color: #D0D0D0;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* ===== 底部占位 ===== */
.bottom-placeholder {
  height: 160rpx;
}

/* ===== 底部按钮 ===== */
.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
