<!--pages/edit-restaurant/edit-restaurant.wxml-->
<view class="container">
  <!-- 表单 -->
  <view class="form">
    <!-- 餐厅名称 -->
    <view class="form-item">
      <view class="form-label">
        <text>餐厅名称</text>
        <text class="required">*</text>
        <text class="char-count">{{restaurantName.length}}/15</text>
      </view>
      <input 
        class="input" 
        placeholder="请输入餐厅名称" 
        value="{{restaurantName}}" 
        bindinput="onNameInput"
        maxlength="15"
      />
    </view>

    <!-- 餐厅地址 -->
    <view class="form-item">
      <view class="form-label">
        <text>餐厅地址</text>
        <text class="char-count">选填 {{restaurantAddress.length}}/30</text>
      </view>
      <textarea 
        class="textarea" 
        placeholder="请输入餐厅地址" 
        value="{{restaurantAddress}}" 
        bindinput="onAddressInput"
        maxlength="30"
        auto-height
      />
    </view>

    <!-- 餐厅标签 -->
    <view class="form-item">
      <view class="form-label">
        <text>餐厅标签</text>
        <text class="char-count">选填 {{restaurantTags.length}}/30</text>
      </view>
      <textarea 
        class="textarea" 
        placeholder="例如: 川菜 实惠 环境好（用空格分隔）" 
        value="{{restaurantTags}}" 
        bindinput="onTagsInput"
        maxlength="30"
        auto-height
      />
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>

  <!-- 固定底部 -->
  <view class="fixed-bottom">
    <!-- 取消和保存按钮 -->
    <view class="action-buttons">
      <view class="btn btn-secondary" bindtap="onCancel">取消</view>
      <view class="btn btn-primary" bindtap="onSave">保存</view>
    </view>

    <!-- ✅ 修复：删除按钮独立一行，不加额外类名 -->
    <view class="btn btn-danger" bindtap="onShowDeleteModal" style="width: 100%;">删除这家餐厅</view>
  </view>

  <!-- 删除确认弹窗 -->
  <view wx:if="{{showDeleteModal}}" class="modal-mask" bindtap="onHideDeleteModal">
    <view class="modal-content" catchtap="doNothing">
      <view class="modal-title">确认删除</view>
      <view class="modal-desc">删除后无法恢复，餐厅及其所有菜品都将被删除</view>
      <view class="modal-actions">
        <view class="btn btn-secondary" bindtap="onHideDeleteModal">取消</view>
        <view class="btn btn-danger" bindtap="onConfirmDelete">确认删除</view>
      </view>
    </view>
  </view>
</view>
