/* pages/edit-restaurant/edit-restaurant.wxss */

.container {
  padding: 32rpx;
  padding-bottom: 260rpx;
  min-height: 100vh;
}

/* ===== 表单 ===== */
.form {
  margin-bottom: 48rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  font-size: var(--font-body);
  font-weight: 500;
  color: var(--color-text-main);
}

.required {
  color: var(--color-avoid);
  font-size: var(--font-body);
}

.char-count {
  margin-left: auto;
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* ===== 底部占位 ===== */
.bottom-placeholder {
  height: 240rpx;
}

/* ===== 底部按钮 ===== */
.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

/* ✅ 修复：删除按钮完整宽度 */
.delete-btn {
  width: 100%;
  box-sizing: border-box;  /* 确保padding不会超出 */
  margin-top: 0;
  padding-left: 32rpx;     /* 与fixed-bottom的padding保持一致 */
  padding-right: 32rpx;    /* 与fixed-bottom的padding保持一致 */
}
