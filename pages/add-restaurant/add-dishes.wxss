/* pages/add-dishes/add-dishes.wxss - 添加菜品（遵循视觉规范）*/

.container {
  padding: 32rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
}

/* ===== 菜品表单卡片 ===== */
.dish-form {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.dish-number {
  font-size: var(--font-caption);
  font-weight: 500;
  color: var(--color-text-sub);
  margin-bottom: 20rpx;
  letter-spacing: 0.5rpx;
}

/* ===== 表单项 ===== */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: var(--font-body);
  color: var(--color-text-main);
  margin-bottom: 12rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.char-count {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  font-weight: 400;
}

/* 输入框 */
.form-input, .form-textarea {
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 20rpx;
  font-size: var(--font-body);
  color: var(--color-text-main);
  letter-spacing: 0.5rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-input {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  line-height: 1.5;
}

.form-textarea {
  min-height: 160rpx;
  line-height: 1.6;
}

.form-input::placeholder, .form-textarea::placeholder {
  color: var(--color-text-sub);
  font-weight: 400;
}

/* ===== 评分按钮 ===== */
.rating-buttons {
  display: flex;
  gap: 12rpx;
}

.rating-btn {
  flex: 1;
  background: #FAFAFA;
  border-radius: var(--radius-input);
  padding: 24rpx 0;
  text-align: center;
  transition: all 0.2s ease;
}

.rating-btn:active {
  transform: scale(0.98);
}

.rating-btn.must.active {
  background: var(--color-primary-soft);
}

.rating-btn.avoid.active {
  background: #F2F2F2;
}

.rating-btn-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.rating-btn.active .rating-btn-text {
  color: var(--color-text-main);
}

.rating-btn.must.active .rating-btn-text {
  color: var(--color-primary);
}

/* ===== 照片上传 ===== */
.photo-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-input);
  overflow: hidden;
  background: #FAFAFA;
}

.photo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.photo-delete:active {
  transform: scale(0.9);
}

.delete-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 300;
}

.photo-upload {
  width: 100%;
  height: 300rpx;
  background: #FAFAFA;
  border: 2rpx dashed #E0E0E0;
  border-radius: var(--radius-input);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.photo-upload:active {
  background: #F0F0F0;
  border-color: #D0D0D0;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

/* ===== 底部固定区域 ===== */
.bottom-placeholder {
  height: 160rpx;
}

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  border-radius: var(--radius-button);
  padding: 24rpx 0;
  text-align: center;
  transition: opacity 0.2s ease;
}

.btn-cancel {
  background: #EFEFEF;
}

.btn-cancel:active {
  opacity: 0.8;
}

.btn-save {
  background: var(--color-primary);
}

.btn-save:active {
  opacity: 0.8;
}

.action-btn-text {
  font-size: var(--font-body);
  color: var(--color-text-normal);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.btn-save .action-btn-text {
  color: #FFFFFF;
}
