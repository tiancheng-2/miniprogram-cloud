/* pages/restaurant/restaurant.wxss - 餐厅详情（遵循视觉规范）*/

.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
}

/* ===== 餐厅头部 ===== */
.restaurant-header {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.restaurant-info {
  flex: 1;
}

.restaurant-name {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-main);
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.restaurant-address {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 400;
  letter-spacing: 0.5rpx;
  line-height: 1.6;
}

.header-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.share-icon, .edit-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  color: var(--color-text-sub);
  background: #FAFAFA;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.share-icon:active, .edit-icon:active {
  background: #F0F0F0;
  transform: scale(0.92);
}

/* ===== 筛选标签 ===== */
.filter-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.filter-tab {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-button);
  padding: 24rpx 0;
  text-align: center;
  font-size: var(--font-body);
  font-weight: 500;
  color: var(--color-text-sub);
  transition: all 0.2s ease;
  letter-spacing: 0.5rpx;
  box-shadow: var(--shadow-card);
}

.filter-tab:active {
  transform: scale(0.98);
}

.filter-tab.active {
  background: var(--color-primary);
  color: white;
}

.filter-tab-text {
  font-size: var(--font-body);
  font-weight: 500;
}

/* ===== 菜品列表 ===== */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dish-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
  display: flex;
  flex-direction: row;
}

.dish-card:active {
  transform: scale(0.98);
}

.dish-image {
  width: 240rpx;
  height: auto;
  min-height: 240rpx;
  background: #FAFAFA;
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: stretch;
}

.dish-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 300;
  color: #E0E0E0;
}

.dish-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.dish-name {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  letter-spacing: 0.5rpx;
  flex: 1;
  padding-right: 12rpx;
}

.dish-rating {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  flex-shrink: 0;
}

.dish-rating.must {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.dish-rating.avoid {
  background: #F2F2F2;
  color: var(--color-text-sub);
}

.dish-note {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-tag {
  padding: 6rpx 16rpx;
  background: #F2F2F2;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  color: var(--color-text-sub);
}

.view-empty {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  padding: 240rpx 0;
}

/* ===== 底部按钮 ===== */
.fixed-bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
  display: flex;
  gap: 12rpx;
}

.back-button, .add-button {
  flex: 1;
  background: #EFEFEF;
  border-radius: var(--radius-button);
  padding: 24rpx 0;
  text-align: center;
  font-size: var(--font-body);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  color: var(--color-text-normal);
  transition: opacity 0.2s ease;
}

.add-button {
  background: var(--color-primary);
  color: #FFFFFF;
}

.back-button:active, .add-button:active {
  opacity: 0.8;
}

/* ===== 分享弹窗样式 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selector-modal, .style-modal {
  width: 85%;
  max-width: 650rpx;
  max-height: 80vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 32rpx 24rpx;
  box-shadow: var(--shadow-popup);
  display: flex;
  flex-direction: column;
}

.modal-title {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 0.5rpx;
}

.dish-scroll {
  flex: 1;
  max-height: 50vh;
  margin-bottom: 24rpx;
}

.dish-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  letter-spacing: 0.5rpx;
}

.select-item {
  display: flex;
  align-items: center;
  padding: 20rpx 12rpx;
  margin-bottom: 8rpx;
  background: #FAFAFA;
  border-radius: var(--radius-input);
  transition: all 0.2s ease;
}

.select-item:active {
  transform: scale(0.98);
}

.select-item.selected {
  background: var(--color-primary-soft);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.select-item.selected .checkbox {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.check-mark {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}

.item-name {
  flex: 1;
  font-size: var(--font-body);
  color: var(--color-text-main);
  letter-spacing: 0.5rpx;
}

/* 风格选择 */
.style-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.style-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.style-card:active {
  transform: scale(0.95);
}

.style-preview {
  width: 180rpx;
  height: 240rpx;
  border-radius: var(--radius-input);
  margin-bottom: 8rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.style-card.selected .style-preview {
  border-color: var(--color-primary);
}

.style-name {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  text-align: center;
  letter-spacing: 0.5rpx;
}

.style-card.selected .style-name {
  color: var(--color-primary);
  font-weight: 600;
}

.selected-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

/* 弹窗按钮 */
.modal-actions {
  display: flex;
  gap: 12rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: var(--radius-button);
  text-align: center;
  font-size: var(--font-body);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  transition: opacity 0.2s ease;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.cancel {
  background: #EFEFEF;
  color: var(--color-text-normal);
}

.modal-btn.confirm {
  background: var(--color-primary);
  color: white;
}
