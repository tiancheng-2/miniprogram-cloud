/* pages/restaurant/restaurant.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ===== 餐厅头部 ===== */
.restaurant-header {
  flex-shrink: 0;
  background: var(--color-bg-card);
  padding: 32rpx;
  margin: 20rpx 32rpx;
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.restaurant-info {
  flex: 1;
}

.restaurant-name {
  font-family: var(--font-serif);
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.restaurant-address {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.restaurant-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.edit-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  color: var(--color-text-sub);
  background: #FAFAFA;
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.edit-icon:active {
  background: #F0F0F0;
  transform: scale(0.92);
}

/* ===== 筛选标签 ===== */
.filter-tabs {
  flex-shrink: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.filter-tab {
  background: var(--color-bg-card);
  border-radius: var(--radius-button);
  padding: 20rpx 0;
  text-align: center;
  font-size: var(--font-body);
  font-weight: 500;
  color: var(--color-text-sub);
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
}

.filter-tab:active {
  transform: scale(0.98);
}

.filter-tab.active {
  background: var(--color-must-try);
  color: #FFFFFF;
}

/* ===== 菜品列表 ===== */
.dish-list {
  flex: 1;
  height: 0;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.dish-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
  display: flex;
  transition: transform 0.2s ease;
}

.dish-card:active {
  transform: scale(0.98);
}

/* 菜品图片 */
.dish-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #FAFAFA;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.image-placeholder {
  font-family: var(--font-serif);
  font-size: 64rpx;
  font-weight: 600;
  color: var(--color-text-sub);
  opacity: 0.3;
}

/* 菜品信息 */
.dish-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.dish-name {
  font-family: var(--font-serif);
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  flex: 1;
  padding-right: 12rpx;
  line-height: 1.3;
}

.dish-rating {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  font-weight: 500;
  flex-shrink: 0;
}

.dish-rating.must {
  background: var(--color-must-try-soft);
  color: var(--color-must-try);
}

.dish-rating.avoid {
  background: var(--color-avoid-soft);
  color: var(--color-avoid);
}

.dish-note {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-tag {
  padding: 4rpx 12rpx;
  background: #F2F2F2;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  color: var(--color-text-sub);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.8;
  white-space: pre-line;
}

/* ===== 底部占位 ===== */
.bottom-placeholder {
  height: 120rpx;
}

/* ===== 底部按钮 ===== */
.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
