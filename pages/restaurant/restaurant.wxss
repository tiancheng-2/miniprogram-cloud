/* pages/restaurant/restaurant.wxss - 餐厅详情（遵循视觉规范）*/

.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
}

/* ===== 餐厅头部 ===== */
.restaurant-header {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.restaurant-info {
  flex: 1;
}

.restaurant-name {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-main);
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.restaurant-address {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  font-weight: 400;
  letter-spacing: 0.5rpx;
  line-height: 1.6;
}

.header-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.share-icon, .edit-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  color: var(--color-text-sub);
  background: #FAFAFA;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.share-icon:active, .edit-icon:active {
  background: #F0F0F0;
  transform: scale(0.92);
}

/* ===== 筛选标签 ===== */
.filter-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.filter-tab {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-button);
  padding: 24rpx 0;
  text-align: center;
  font-size: var(--font-body);
  font-weight: 500;
  color: var(--color-text-sub);
  transition: all 0.2s ease;
  letter-spacing: 0.5rpx;
  box-shadow: var(--shadow-card);
}

.filter-tab:active {
  transform: scale(0.98);
}

.filter-tab.active {
  background: var(--color-primary);
  color: white;
}

.filter-tab-text {
  font-size: var(--font-body);
  font-weight: 500;
}

/* ===== 菜品列表 ===== */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dish-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
  display: flex;
  flex-direction: row;
}

.dish-card:active {
  transform: scale(0.98);
}

.dish-image {
  width: 240rpx;
  height: auto;
  min-height: 240rpx;
  background: #FAFAFA;
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: stretch;
}

.dish-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 300;
  color: #E0E0E0;
}

.dish-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.dish-name {
  font-size: var(--font-subtitle);
  font-weight: 600;
  color: var(--color-text-main);
  letter-spacing: 0.5rpx;
  flex: 1;
  padding-right: 12rpx;
}

.dish-rating {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  flex-shrink: 0;
}

.dish-rating.must {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.dish-rating.avoid {
  background: #F2F2F2;
  color: var(--color-text-sub);
}

.dish-note {
  font-size: var(--font-caption);
  color: var(--color-text-sub);
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-tag {
  padding: 6rpx 16rpx;
  background: #F2F2F2;
  border-radius: var(--radius-tag);
  font-size: var(--font-tag);
  color: var(--color-text-sub);
}

.view-empty {
  font-size: var(--font-body);
  color: var(--color-text-sub);
  text-align: center;
  padding: 240rpx 0;
}

/* ===== 底部按钮 ===== */
.fixed-bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
  display: flex;
  gap: 12rpx;
}

.back-button, .add-button {
  flex: 1;
  background: #EFEFEF;
  border-radius: var(--radius-button);
  padding: 24rpx 0;
  text-align: center;
  font-size: var(--font-body);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  color: var(--color-text-normal);
  transition: opacity 0.2s ease;
}

.add-button {
  background: var(--color-primary);
  color: #FFFFFF;
}

.back-button:active, .add-button:active {
  opacity: 0.8;
}
