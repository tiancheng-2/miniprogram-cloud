<!--pages/restaurant/restaurant.wxml-->
<view class="container">
  <!-- 餐厅头部 -->
  <view class="restaurant-header">
    <view class="restaurant-info">
      <view class="restaurant-name">{{restaurantName}}</view>
      <view wx:if="{{restaurantAddress}}" class="restaurant-address">
        📍 {{restaurantAddress}}
      </view>
      <view wx:if="{{restaurantTags.length > 0}}" class="restaurant-tags">
        <view class="tag" wx:for="{{restaurantTags}}" wx:key="index">{{item}}</view>
      </view>
    </view>
    <view class="edit-icon" bindtap="onEditRestaurant">✏︎</view>
  </view>

  <!-- 筛选标签 -->
  <view wx:if="{{mustTryDishes.length > 0 || avoidDishes.length > 0}}" class="filter-tabs">
    <view 
      class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-filter="all"
    >全部</view>
    <view 
      class="filter-tab {{currentFilter === 'must-try' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-filter="must-try"
    >👍 必点</view>
    <view 
      class="filter-tab {{currentFilter === 'avoid' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-filter="avoid"
    >⚠️ 避坑</view>
  </view>

  <!-- 菜品列表 -->
  <scroll-view 
    class="dish-list" 
    scroll-y
    enhanced
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <!-- 全部视图 -->
    <view wx:if="{{currentFilter === 'all' && (mustTryDishes.length > 0 || avoidDishes.length > 0)}}">
      <block wx:for="{{allDishes}}" wx:key="_id">
        <view class="dish-card" bindtap="onViewDish" data-id="{{item._id}}" data-name="{{item.dishName}}" data-rating="{{item.rating}}">
          <view class="dish-image">
            <image wx:if="{{item.photoUrl}}" class="dish-photo" src="{{item.photoUrl}}" mode="aspectFill"></image>
            <view wx:else class="image-placeholder">{{item.dishChar}}</view>
          </view>
          <view class="dish-info">
            <view class="dish-header">
              <view class="dish-name">{{item.dishName}}</view>
              <view class="dish-rating {{item.rating === 'must-try' ? 'must' : 'avoid'}}">
                {{item.rating === 'must-try' ? '👍 必点' : '⚠️ 避坑'}}
              </view>
            </view>
            <view wx:if="{{item.note}}" class="dish-note">{{item.note}}</view>
            <view wx:if="{{item.tags && item.tags.length > 0}}" class="dish-tags">
              <view class="dish-tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- 必点视图 -->
    <view wx:if="{{currentFilter === 'must-try'}}">
      <block wx:if="{{mustTryDishes.length > 0}}">
        <view class="dish-card" wx:for="{{mustTryDishes}}" wx:key="_id" bindtap="onViewDish" data-id="{{item._id}}" data-name="{{item.dishName}}" data-rating="{{item.rating}}">
          <view class="dish-image">
            <image wx:if="{{item.photoUrl}}" class="dish-photo" src="{{item.photoUrl}}" mode="aspectFill"></image>
            <view wx:else class="image-placeholder">{{item.dishChar}}</view>
          </view>
          <view class="dish-info">
            <view class="dish-header">
              <view class="dish-name">{{item.dishName}}</view>
              <view class="dish-rating must">👍 必点</view>
            </view>
            <view wx:if="{{item.note}}" class="dish-note">{{item.note}}</view>
            <view wx:if="{{item.tags && item.tags.length > 0}}" class="dish-tags">
              <view class="dish-tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</view>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-state">
        <text class="empty-text">还没有必点菜品</text>
      </view>
    </view>

    <!-- 避坑视图 -->
    <view wx:if="{{currentFilter === 'avoid'}}">
      <block wx:if="{{avoidDishes.length > 0}}">
        <view class="dish-card" wx:for="{{avoidDishes}}" wx:key="_id" bindtap="onViewDish" data-id="{{item._id}}" data-name="{{item.dishName}}" data-rating="{{item.rating}}">
          <view class="dish-image">
            <image wx:if="{{item.photoUrl}}" class="dish-photo" src="{{item.photoUrl}}" mode="aspectFill"></image>
            <view wx:else class="image-placeholder">{{item.dishChar}}</view>
          </view>
          <view class="dish-info">
            <view class="dish-header">
              <view class="dish-name">{{item.dishName}}</view>
              <view class="dish-rating avoid">⚠️ 避坑</view>
            </view>
            <view wx:if="{{item.note}}" class="dish-note">{{item.note}}</view>
            <view wx:if="{{item.tags && item.tags.length > 0}}" class="dish-tags">
              <view class="dish-tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</view>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-state">
        <text class="empty-text">还没有避坑菜品</text>
      </view>
    </view>

    <!-- 无菜品提示 -->
    <view wx:if="{{mustTryDishes.length === 0 && avoidDishes.length === 0}}" class="empty-state">
      <text class="empty-icon">🍽️</text>
      <text class="empty-text">还没有记录菜品
点击下方按钮记下第一道吧</text>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 固定底部按钮 -->
  <view class="fixed-bottom">
    <view class="action-buttons">
      <view class="btn btn-secondary" bindtap="onBack">返回</view>
      <view class="btn btn-primary" bindtap="goToAddDishes">新增菜品</view>
    </view>
  </view>
</view>
