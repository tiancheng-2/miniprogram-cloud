/* pages/share-poster/share-poster.wxss - 海报感样式 */

.poster-container {
  min-height: 100vh;
  padding: 80rpx 60rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  display: flex;
  flex-direction: column;
}

/* ===== 餐厅名（视觉中心）===== */
.restaurant-name {
  font-size: 64rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  line-height: 1.3;
}

/* ===== 推荐语 ===== */
.recommendation {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  letter-spacing: 2rpx;
  margin-bottom: 80rpx;
  font-weight: 400;
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 64rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}

/* ===== 必点区域 ===== */
.must-try-section .section-title {
  color: var(--color-primary);
}

/* ===== 避坑区域（弱化）===== */
.avoid-section {
  opacity: 0.7;
}

.avoid-section .section-title {
  color: #666;
  font-size: 32rpx;
}

/* ===== 菜品列表（文案式）===== */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.dish-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-left: 24rpx;
  position: relative;
}

/* 列表项标记 */
.dish-item::before {
  content: '•';
  position: absolute;
  left: 0;
  top: 2rpx;
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: bold;
}

.avoid-section .dish-item::before {
  color: #999;
}

.dish-name {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1.4;
}

.avoid-section .dish-name {
  color: #666;
}

.dish-note {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
}

.avoid-section .dish-note {
  color: #999;
}

/* ===== 底部品牌（不可点击）===== */
.brand {
  margin-top: auto;
  padding-top: 80rpx;
  text-align: center;
}

.brand-text {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 2rpx;
  font-weight: 400;
}
